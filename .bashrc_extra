# terminal title shows user@host only over SSH
if [ -n "$SSH_CONNECTION" ]; then
    PS1='\[\e]0;\u@\h: \w\a\]\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='\[\e]0;\w\a\]\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
fi


# PATH without duplicates

# Python
PATH="$HOME/.local/python-3.11.9/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
PATH="$PNPM_HOME:$PATH"

# Maven
export MAVEN_HOME="$HOME/tools/apache-maven-3.9.14"
PATH="$MAVEN_HOME/bin:$PATH"

# IntelliJ IDEA
PATH="$HOME/apps/idea-IU-261.22158.277/bin:$PATH"

# Local Bin (For Claude and other local tools)
PATH="$HOME/.local/bin:$PATH"

# --- AUTOMATED DEDUPLICATION ---  keep all additions to PATH above this!
clean_path() {
    local IFS=':'
    local old_path=($PATH)
    local new_path=()
    local seen; declare -A seen
    for dir in "${old_path[@]}"; do
        if [[ -n "$dir" && -z "${seen[$dir]}" ]]; then
            new_path+=("$dir")
            seen[$dir]=1
        fi
    done
    PATH="${new_path[*]}"
}
clean_path
export PATH
unset -f clean_path


alias bat='batcat --paging=never'

if [ -f ~/.fzf.bash ]; then
    source ~/.fzf.bash
elif [ -f /usr/share/doc/fzf/examples/key-bindings.bash ]; then
    source /usr/share/doc/fzf/examples/key-bindings.bash
fi
# Show preview: batcat for file, tree for dir
export FZF_DEFAULT_OPTS='
  --border
  --preview="
    if [ -d {} ]; then
      tree -C -L 2 {} | head -200
    else
      batcat --style=numbers --color=always {} 2>/dev/null || file {}
    fi
  "
'

# ctrl + f to open file/dir with default app
fopen() {
  local target
  target=$(find . -name '.git' -prune -printf '%p/\n' -o \( -type d -printf '%p/\n' -o -type f -print \) 2>/dev/null | fzf --prompt="Open > ") || return
  target="${target%/}"
  xdg-open "$target" >/dev/null 2>&1
}
bind -r "\C-f"
bind -x '"\C-f": "fopen"'

# ctrl + r command history using fzf
export FZF_CTRL_R_OPTS="
  --height 40%
  --layout=reverse
  --border
  --no-preview
  --scheme=history
"

# find alternatively
alias fd=fdfind
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# ctrl + t command snippets
snippets() {
    local selected cmd
    selected=$(grep -v '^#\|^$' ~/.bash_commands_guide | \
        fzf --delimiter=' :: ' \
            --with-nth=1,2 \
            --prompt="snippets > " \
            --preview='echo {2}' \
            --preview-window='bottom,3,wrap') || return
    cmd="${selected%% :: *}"
    READLINE_LINE="$cmd"
    READLINE_POINT=${#cmd}
}
bind -r "\C-t"
bind -x '"\C-t": snippets'

# mkfile to create new/dir/file.ext
mkfile() {
    if [ -d "$1" ]; then
        echo "mkfile: '$1' is a directory" >&2
        return 1
    fi
    if [ -e "$1" ]; then
        echo "mkfile: '$1' already exists" >&2
        return 1
    fi
    mkdir -p "$(dirname "$1")" && touch "$1"
}

# ctrl + g search in files
search_in_files() {
    local output query filename linenum line

    output=$(
        FZF_DEFAULT_COMMAND='true' \
        fzf --ansi \
            --disabled \
            --print-query \
            --delimiter ':' \
            --prompt="Live rg > " \
            --preview 'batcat --style=numbers --color=always --highlight-line {2} {1} 2>/dev/null' \
            --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \
            --bind 'change:reload:if [ -z {q} ]; then true; else rg --line-number --with-filename --no-heading --color=always --smart-case -e {q} || true; fi'
    )

    [ -z "$output" ] && return

    query=${output%%$'\n'*}
    output=${output#*$'\n'}

    [ -z "$output" ] && return

    filename=${output%%:*}
    output=${output#*:}

    linenum=${output%%:*}
    line=${output#*:}

    # re-apply the exact highlight.
    if [ -n "$query" ]; then
        line=$(printf "%s\n" "$line" | rg --color=always --smart-case -e "$query" 2>/dev/null || printf "%s\n" "$line")
    fi

    printf '\e[1;33m%s\e[0m\n' "$query"
    printf '\e[1;34m%s\e[0m\n' "$(realpath "$filename")"
    printf '\e[1;33m%s:\e[0m %s\n' "$linenum" "$line"
}

bind '"\C-g": "\C-a\C-k search_in_files\n"'
